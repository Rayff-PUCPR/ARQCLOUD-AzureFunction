{
  "name": "rotacerta-azure-function",
  "version": "1.0.0",
  "private": true,
  "main": "dist/functions/*.js",
  "scripts": {
    "dev": "tsx watch src/local-server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/local-server.js",
    "test": "vitest run --exclude \"dist/**\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@azure/functions": "^4.7.2",
    "dotenv": "^17.4.2",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
